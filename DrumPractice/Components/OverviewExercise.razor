@using DrumPractice.Models

<MudItem xs="12" sm="6" md="3">
    <MudCard>
        <MudCardHeader>
            <CardHeaderAvatar>
                <MudAvatar Color="Color.Error" Variant="Variant.Outlined">
                    <MudIcon Icon="@Icons.Material.Filled.MusicNote" Color="Color.Error" Size="Size.Medium" />
                </MudAvatar>
            </CardHeaderAvatar>
            <CardHeaderContent>
                <MudText Typo="Typo.h5">@item.Name</MudText>
            </CardHeaderContent>
            <ChildContent>
                <MudToggleIconButton Icon="@Icons.Material.Filled.Lightbulb"  DropShadow="true" ToggledIcon="@Icons.Material.Filled.Light" @bind-Toggled="_expand"/>
            </ChildContent>
        </MudCardHeader>
        <MudCardContent>
            <MudCardMedia Image="@item.ImageUrl" Style="background-size: cover;" Height="150" />
            <MudCollapse Expanded="_expand">
                <MudCardContent>
                    @item.Description
                </MudCardContent>
            </MudCollapse>
        </MudCardContent>
        <MudCardActions Class="p-0">
            <MudButton Size="Size.Large" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.RocketLaunch" Color="Color.Error" FullWidth="true" Href="@($"/PracticeDetail/{item.Id}")">Practice now</MudButton>
        </MudCardActions>

    </MudCard>
</MudItem>

@code {
    [Parameter]
    public required Exercise item { get; set; }
    bool _expand = false;
}