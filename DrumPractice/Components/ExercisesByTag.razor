@page "/Rudiment/ExercisesByTag/{tag}"
@using DrumPractice.Models
@using DrumPractice.Services
@inject ExerciseService exerciseService

<MudContainer Class="mt-16">
    <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">@tag</MudText>
    <MudGrid Class="mt-8">
            @if (Exercises == null)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" Class="mx-auto" />
            }
            else{
                @foreach (var item in Exercises)
                {
                    <OverviewExercise item="item" />
                }
            }
    </MudGrid>
</MudContainer>

@code {
    [Parameter]
    public required string tag { get; set; }
    public List<Exercise>? Exercises {get; set; }

    protected override async Task OnParametersSetAsync()
    {
        // Decode in case of URL encoding
        tag = Uri.UnescapeDataString(tag);
    }

    protected override async Task OnInitializedAsync()
    {
        Exercises = await exerciseService.GetExercisesByTagAsync(tag);
    }
}