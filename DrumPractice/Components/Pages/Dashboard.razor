@page "/"
@using DrumPractice.Components.Card
@using DrumPractice.Models

<MudContainer Class="mt-16">
    <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">Let's get practicing!</MudText>
    <MudText Typo="Typo.h6" Align="Align.Center">"You only get better by playing."</MudText>
    <MudGrid Class="mt-2">
        <MudItem xs="12" sm="6" md="3">
            <BaseCard Title="Rudiments" Color="Color.Error" Icon="@Icons.Material.Filled.LibraryMusic" Items=Rudiments/>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <BaseCard Title="Exercises" Color="Color.Success" Icon="@Icons.Material.Filled.Checklist" Items=Exercises />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <BaseCard Title="Fills" Color="Color.Warning" Icon="@Icons.Material.Filled.Category" Items=Fills />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <BaseCard Title="Books" Color="Color.Info" Icon="@Icons.Material.Filled.AutoStories" Items=Books />
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    List<CardItem> Rudiments = new List<CardItem> {
        new CardItem { Name = "Rolls", Href = "/Rudiment/ExercisesByTag/Roll%20Rudiments" },
        new CardItem { Name = "Diddles", Href = "/Rudiment/ExercisesByTag/Diddle%20Rudiments" },
        new CardItem { Name = "Flams", Href = "/Rudiment/ExercisesByTag/Flam%20Rudiments" },
        new CardItem { Name = "Drags", Href = "/Rudiment/ExercisesByTag/Drag%20Rudiments" },
    };

    List<CardItem> Exercises = new List<CardItem> {
        new CardItem { Name = "HiHat", Href = "/HiHat" },
        new CardItem { Name = "Single Pedal", Href = "/Single%20Pedal" },
        new CardItem { Name = "Double Bass", Href = "/Double%20Bass" },
    };

    List<CardItem> Fills = new List<CardItem> { 
        new CardItem { Name = "Back To Basics", Href = "" }, 
        new CardItem { Name = "Fifteen Favourites", Href = "" },
        new CardItem { Name = "ABCD", Href = "" },
    };

    List<CardItem> Books = new List<CardItem> { 
        new CardItem { Name = "Paradiddle Power", Href = "" },
        new CardItem { Name = "The drummers cookbook", Href = "" },
        new CardItem { Name = "Master Studies", Href = "" },
    };
}