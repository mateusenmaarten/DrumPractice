@page "/PracticeDetail/{exerciseId:int}"
@using DrumPractice.Models
@using DrumPractice.Services
@implements IDisposable
@inject ExerciseService exerciseService

@if (Exercise == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
}
else
{
    <MudCard>
        <MudCardHeader>
            <CardHeaderAvatar>
                <MudAvatar Color="Color.Error" Variant="Variant.Outlined">
                    <MudIcon Icon="@Icons.Material.Filled.MusicNote" Color="Color.Error" Size="Size.Medium" />
                </MudAvatar>
            </CardHeaderAvatar>
            <CardHeaderContent>
                <MudText Typo="Typo.body1">@Exercise.Name</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardMedia Image="@Exercise.ImageUrl" Style="background-size: contain;" />
        <MudCardContent>
            <MudText Typo="Typo.body2">@Exercise.Description</MudText>
        </MudCardContent>
        <MudCardActions>
            <MudStack Spacing="2">
                <MudCollapse Expanded="_expanded">
                    <MudCardActions>
                        <MudToggleIconButton @bind-Toggled="TimerRunning"
                                             Icon="@Icons.Material.Filled.PlayArrow"
                                             Color="@Color.Error"
                                             ToggledIcon="@Icons.Material.Filled.Pause"
                                             ToggledColor="@Color.Error"
                                             title="@(TimerRunning ? "Pause" : "Start")" />
                        <MudText Typo="Typo.body1">@FormatTime(ElapsedSeconds)</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                       Color="@Color.Error"
                                       OnClick="ResetTimer"
                                       title="Reset" />
                    </MudCardActions>
                </MudCollapse>
            </MudStack>
        </MudCardActions>
    </MudCard>
}

@code {
    // The exercise ID is passed as a route parameter
    [Parameter]
    public int ExerciseId { get; set; }

    private Exercise? Exercise { get; set; }
    private bool TimerRunning { get; set; }
    private int ElapsedSeconds { get; set; }
    private System.Threading.Timer? timer;
    bool _expanded = true;

    protected override async Task OnInitializedAsync()
    {
        // Load the exercise from the database
        Exercise = await exerciseService.GetExerciseByIdAsync(ExerciseId);

        timer = new System.Threading.Timer(async _ =>
        {
            if (TimerRunning)
            {
                ElapsedSeconds++;
                await InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private string FormatTime(int totalSeconds)
    {
        int minutes = totalSeconds / 60;
        int seconds = totalSeconds % 60;
        return $"{minutes:D2}:{seconds:D2}";
    }

    private void ResetTimer()
    {
        ElapsedSeconds = 0;
        TimerRunning = false;
    }

    public void Dispose()
    {
        timer?.Dispose();
    }
}