@page "/"

<MudContainer Class="mt-16">
    <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">Let's get practicing!</MudText>
    <MudText Typo="Typo.h5" Align="Align.Center">"You only get better by playing."</MudText>
    <MudGrid Class="mt-8">
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="25" Class="rounded-lg pb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5" Align="Align.Center">Rudiments</MudText>
                        <div class="d-flex justify-center">
                            <MudIcon Icon="@Icons.Material.Filled.LibraryMusic" Color="Color.Error"></MudIcon>
                        </div>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudList T="string" Class="mx-auto mt-4" Style="width:300px;">
                        <MudListItem Href="Rudiment/Diddles" Icon="@Icons.Material.Filled.ArrowRight" IconColor="Color.Primary">
                            Diddles
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.ArrowRight" IconColor="Color.Primary">
                            Drags
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.ArrowRight" IconColor="Color.Primary">
                            Flams
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.ArrowRight" IconColor="Color.Primary">
                            Rolls
                        </MudListItem>
                    </MudList>
                </MudCardContent>
                <MudCardActions Class="d-flex justify-center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Style="width:50%;" Href="Rudiments">Go!</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="25" Class="rounded-lg pb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5" Align="Align.Center">Exercise</MudText>
                        <div class="d-flex justify-center">
                            <MudIcon Icon="@Icons.Material.Filled.Checklist" Color="Color.Success"></MudIcon>
                        </div>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudList T="string" Class="mx-auto mt-4" Style="width:300px;">
                        <MudListItem Icon="@Icons.Material.Filled.ArrowRight" IconColor="Color.Primary">
                           Hihat
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.ArrowRight" IconColor="Color.Primary">
                            Single pedal
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.ArrowRight" IconColor="Color.Primary">
                            Double bass
                        </MudListItem>
                    </MudList>
                </MudCardContent>
                <MudCardActions Class="d-flex justify-center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Style="width:50%;">Go!</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="25" Class="rounded-lg pb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5" Align="Align.Center">Fills</MudText>
                        <div class="d-flex justify-center">
                            <MudIcon Icon="@Icons.Material.Filled.Category" Color="Color.Warning"></MudIcon>
                        </div>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudList T="string" Class="mx-auto mt-4" Style="width:300px;">
                        <MudListItem Icon="@Icons.Material.Filled.ArrowRight" IconColor="Color.Primary">
                            Back to basics
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.ArrowRight" IconColor="Color.Primary">
                            Fifteen favourites
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.ArrowRight" IconColor="Color.Primary">
                            ABCD
                        </MudListItem>
                    </MudList>
                </MudCardContent>
                <MudCardActions Class="d-flex justify-center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Style="width:50%;">Go!</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="25" Class="rounded-lg pb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5" Align="Align.Center">Books</MudText>
                        <div class="d-flex justify-center">
                            <MudIcon Icon="@Icons.Material.Filled.AutoStories" Color="Color.Info"></MudIcon>
                        </div>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudList T="string" Class="mx-auto mt-4" Style="width:300px;">
                        <MudListItem Icon="@Icons.Material.Filled.ArrowRight" IconColor="Color.Primary">
                            Paradiddle Power - Ron Spagnardi
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.ArrowRight" IconColor="Color.Primary">
                            The drummers cookbook - John Pickering
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Filled.ArrowRight" IconColor="Color.Primary">
                            Master Studies
                        </MudListItem>
                    </MudList>
                </MudCardContent>
                <MudCardActions Class="d-flex justify-center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Style="width:50%;">Go!</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>
