@page "/PracticeDetail/{exerciseId:int}"
@using DrumPractice.Models
@using DrumPractice.Services
@implements IDisposable
@inject ExerciseService exerciseService
@inject PracticeLogService practiceLogService

@if (Exercise == null)
{
    <MudProgressCircular Color="Color.Error" Indeterminate="true" Size="Size.Large" />
}
else
{
    <!-- Image -->
    <div style="margin-top:40px; margin-left:-16px; margin-right:-16px;">
        <MudCardMedia Image="@Exercise.ImageUrl" Height="200"
                      Style="background-size:cover; background-position:center; width:100%;" />
    </div>
    <MudStack Spacing="2">

        <MudCard Elevation="0">
            <MudCardContent>
                <!-- Title -->  
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                    <MudAvatar Color="Color.Error" Variant="Variant.Outlined">
                        <MudIcon Icon="@Icons.Material.Filled.MusicNote" Color="Color.Error" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6">@Exercise.Name</MudText>
                </MudStack>
                <!-- BPM -->
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mt-2">

                    <!-- Decrement -->
                    <MudStack Spacing="1" AlignItems="AlignItems.Center">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                   OnClick="() => ChangeBpm(-10)">−10</MudButton>
                        <MudIconButton Icon="@Icons.Material.Filled.Remove" Color="Color.Error"
                                       Variant="Variant.Outlined" OnClick="() => ChangeBpm(-1)" />
                    </MudStack>

                    <!-- BPM Display -->
                    <MudStack AlignItems="AlignItems.Center" Spacing="0">
                        <MudText Typo="Typo.h2" Color="Color.Error" Style="font-weight:800;letter-spacing:-2px">@bpm</MudText>
                        <MudText Typo="Typo.overline" Color="Color.Secondary">BPM</MudText>
                    </MudStack>

                    <!-- Increment -->
                    <MudStack Spacing="1" AlignItems="AlignItems.Center">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                   OnClick="() => ChangeBpm(10)">+10</MudButton>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Error"
                                       Variant="Variant.Outlined" OnClick="() => ChangeBpm(1)" />
                    </MudStack>

                </MudStack>
                <MudSlider @bind-Value="bpm" Min="40" Max="220" Color="Color.Error" Class="mt-2" />
            </MudCardContent>
        </MudCard>

        <!-- Timers: side by side -->
        <MudGrid Spacing="3">

            <!-- Stopwatch -->
            <MudItem xs="6">
                <MudCard Elevation="2" Style="height:100%">
                    <MudCardContent>
                        <MudText Typo="Typo.overline" Color="Color.Secondary">Stopwatch</MudText>
                        <MudText Typo="Typo.h4" Style="font-variant-numeric:tabular-nums;font-weight:700" Class="my-2">
                            @FormatTime(stopwatchElapsedSeconds)
                        </MudText>
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudIconButton Icon="@(stopwatchRunning? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)"
                                           Color="Color.Error"
                                           Variant="Variant.Filled"
                                           OnClick="ToggleStopwatch" />
                            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                           Color="Color.Default"
                                           Variant="Variant.Outlined"
                                           OnClick="ResetStopwatch" />
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Countdown -->
            <MudItem xs="6">
                <MudCard Elevation="2" Style="height:100%">
                    <MudCardContent>
                        <MudText Typo="Typo.overline" Color="Color.Secondary">Countdown</MudText>
                        <MudText Typo="Typo.h4"
                                 Color="@(RemainingSeconds == 0 && countdownElapsedSeconds > 0 ? Color.Success : Color.Error)"
                                 Style="font-variant-numeric:tabular-nums;font-weight:700" Class="my-2">
                            @(RemainingSeconds == 0 && countdownElapsedSeconds > 0 ? "Done!" : FormatTime(RemainingSeconds))
                        </MudText>
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudIconButton Icon="@(countdownRunning? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)"
                                           Color="Color.Error"
                                           Variant="Variant.Filled"
                                           OnClick="ToggleCountdown"
                                           Disabled="@(RemainingSeconds == 0 && countdownElapsedSeconds > 0)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                           Color="Color.Default"
                                           Variant="Variant.Outlined"
                                           OnClick="ResetCountdown" />
                        </MudStack>
                        <MudProgressLinear Color="@(RemainingSeconds == 0 && countdownElapsedSeconds > 0 ? Color.Success : Color.Error)"
                                           Value="@GetCountdownProgress()"
                                           Max="100"
                                           Rounded="true"
                                           Size="Size.Small"
                                           Class="mt-3" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            @FormatTime(RemainingSeconds) remaining
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

        </MudGrid>

        <!-- Countdown Duration Picker -->
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.overline" Color="Color.Secondary" GutterBottom="true">Set Duration</MudText>
                <MudChipSet T="int" @bind-SelectedValue="targetMinutes" SelectionMode="SelectionMode.SingleSelection">
                    @foreach (var min in new[] { 5, 10, 15, 20, 30, 45, 60 })
                    {
                        <MudChip T="int" Value="min"
                                 Color="@(targetMinutes == min ? Color.Error : Color.Default)"
                                 Variant="@(targetMinutes == min ? Variant.Filled : Variant.Outlined)"
                                 Disabled="@countdownRunning"
                                 OnClick="() => SetDuration(min)">
                            @min min
                        </MudChip>
                    }
                </MudChipSet>
            </MudCardContent>
        </MudCard>

        <!-- Log Practice -->
        <MudButton Variant="Variant.Filled"
                   Color="Color.Error"
                   Size="Size.Large"
                   FullWidth="true"
                   Disabled="@(!CanLog)"
                   StartIcon="@Icons.Material.Filled.LibraryAdd"
                   OnClick="LogPracticeAsync">
            Log Practice
        </MudButton>

    </MudStack>
}

@code {
    [Parameter]
    public int ExerciseId { get; set; }

    private Exercise? Exercise { get; set; }
    private System.Threading.Timer? timer;

    #region BPM
    private int bpm = 120;

    private void ChangeBpm(int delta) => bpm = Math.Clamp(bpm + delta, 40, 220);
    #endregion

    #region Stopwatch
    private int stopwatchElapsedSeconds;
    private bool stopwatchRunning;

    private void ToggleStopwatch() => stopwatchRunning = !stopwatchRunning;
    private void ResetStopwatch() { stopwatchElapsedSeconds = 0; stopwatchRunning = false; }
    #endregion

    #region Countdown
    private int targetMinutes = 10;
    private int countdownElapsedSeconds;
    private bool countdownRunning;

    private int TargetSeconds => targetMinutes * 60;
    private int RemainingSeconds => Math.Max(0, TargetSeconds - countdownElapsedSeconds);

    private double GetCountdownProgress()
    {
        if (TargetSeconds == 0) return 0;
        return (double)RemainingSeconds / TargetSeconds * 100;
    }

    private void ToggleCountdown() => countdownRunning = !countdownRunning;
    private void ResetCountdown() { countdownElapsedSeconds = 0; countdownRunning = false; }
    private void SetDuration(int minutes) { targetMinutes = minutes; countdownElapsedSeconds = 0; countdownRunning = false; }
    #endregion

    #region Log
    private bool CanLog => stopwatchElapsedSeconds > 0 || countdownElapsedSeconds > 0;

    private async Task LogPracticeAsync()
    {
        var log = new PracticeLog
        {
            ExerciseId = ExerciseId,
            Date = DateTime.Now,
            SecondsPracticed = (countdownElapsedSeconds > 0) ? countdownElapsedSeconds : stopwatchElapsedSeconds,
            BpmUsed = bpm,
            Rating = 3 // TODO -> add a rating system (1 - 5 stars?)
        };

        await practiceLogService.AddPracticeLogAsync(log);
        // Reset timers after logging
        ResetStopwatch();
        ResetCountdown();
    }
    #endregion

    #region Shared
    private string FormatTime(int totalSeconds)
    {
        int minutes = totalSeconds / 60;
        int seconds = totalSeconds % 60;
        return $"{minutes:D2}:{seconds:D2}";
    }

    public void Dispose() => timer?.Dispose();
    #endregion

    protected override async Task OnInitializedAsync()
    {
        Exercise = await exerciseService.GetExerciseByIdAsync(ExerciseId);

        timer = new System.Threading.Timer(async _ =>
        {
            var changed = false;

            if (stopwatchRunning) { stopwatchElapsedSeconds++; changed = true; }

            if (countdownRunning)
            {
                if (RemainingSeconds > 0) { countdownElapsedSeconds++; changed = true; }
                if (RemainingSeconds == 0)
                {
                    countdownRunning = false;
                    // Play sound
                    changed = true;
                }
            }

            if (changed)
                await InvokeAsync(StateHasChanged);

        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }
}
