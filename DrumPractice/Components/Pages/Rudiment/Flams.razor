@page "/Rudiment/Flams"
@using DrumPractice.Models
@using DrumPractice.Services
@inject ExerciseService exerciseService

<MudContainer Class="mt-16">
    <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">Flam rudiments</MudText>
    <MudGrid Class="mt-8">
            @if (Exercises == null)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" Class="mx-auto" />
            }
            else{
                @foreach (var item in Exercises)
                {
                    <MudItem xs="12" sm="6" md="3">
                        <MudCard>
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar Color="Color.Error" Variant="Variant.Outlined">
                                        <MudIcon Icon="@Icons.Material.Filled.MusicNote" Color="Color.Error" Size="Size.Medium" />
                    
                                    </MudAvatar>
                                </CardHeaderAvatar>

                                <CardHeaderContent>
                                    <MudText Typo="Typo.body1">@item.Name</MudText>
 
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardMedia Image="/images/40_International_Drum_Rudiments/Diddle_Rudiments/rudiment-16.png" Style="background-size: contain;" />
                            <MudCardContent>
                            @if (item.Tags != null && item.Tags.Any())
                            {
                                @foreach (var tag in item.Tags)
                                {
                                    <MudChip T="string" Color="Color.Secondary">@tag.Name</MudChip>
                                }
                            }
                            </MudCardContent>
                            <MudCardActions>
                            <MudButton Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.PlayForWork" Color="Color.Primary" Href="@($"/PracticeDetail/{item.Id}")">
                                Practice now
                            </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            }
    </MudGrid>
</MudContainer>

@code {
    public List<Exercise>? Exercises {get; set; }

    protected override async Task OnInitializedAsync()
    {
        Exercises = await exerciseService.GetExercisesAsync();
    }
}