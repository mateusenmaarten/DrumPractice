@page "/Rudiment/Diddles"
@using DrumPractice.Models
@using DrumPractice.Services
@implements IDisposable
@inject ExerciseService exerciseService

<MudContainer Class="mt-16">
    <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">Let's get practicing!</MudText>
    <MudText Typo="Typo.h5" Align="Align.Center">"You only get better by playing."</MudText>
    <MudGrid Class="mt-8">
        <MudItem xs="12" sm="6" md="3">
            @if (Exercises == null)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" Class="mx-auto" />
            }
            else{
                @foreach (var item in Exercises)
                {
                    <MudCard>
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar Color="Color.Error" Variant="Variant.Outlined">
                                    <MudIcon Icon="@Icons.Material.Filled.MusicNote" Color="Color.Error" Size="Size.Medium" />
                                </MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.body1">@item.Name</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardMedia Image="/images/40_International_Drum_Rudiments/Diddle_Rudiments/rudiment-16.png" Style="background-size: contain;" />
                        <MudCardContent>
                            <MudText Typo="Typo.body2">@item.Description</MudText>
                        </MudCardContent>

                        <MudCardActions>
                            <MudStack Spacing="2">
                                <MudCollapse Expanded="_expanded">
                                    <MudCardActions>
                                        <MudToggleIconButton @bind-Toggled="TimerRunning"
                                                             Icon="@Icons.Material.Filled.PlayArrow"
                                                             Color="@Color.Error"
                                                             ToggledIcon="@Icons.Material.Filled.Pause"
                                                             ToggledColor="@Color.Error"
                                                             title="@(TimerRunning ? "Pause" : "Start")" />
                                        <MudText Typo="Typo.body1">@FormatTime(ElapsedSeconds)</MudText>
                                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                                       Color="@Color.Error"
                                                       OnClick="ResetTimer"
                                                       title="Reset" />
                                    </MudCardActions>
                                </MudCollapse>
                            </MudStack>
                        </MudCardActions>
                    </MudCard>
                }
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private bool TimerRunning { get; set; }
    private int ElapsedSeconds { get; set; }
    private System.Threading.Timer? timer;

    bool _expanded = true;

    private void OnExpandCollapseClick()
    {
        _expanded = !_expanded;
    }

    protected override async Task OnInitializedAsync()
    {

        Exercises = await exerciseService.GetExercisesAsync();

        timer = new System.Threading.Timer(async _ =>
        {
            if (TimerRunning)
            {
                ElapsedSeconds++;
                await InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private string FormatTime(int totalSeconds)
    {
        int minutes = totalSeconds / 60;
        int seconds = totalSeconds % 60;
        return $"{minutes:D2}:{seconds:D2}";
    }

    private void ResetTimer()
    {
        ElapsedSeconds = 0;
        TimerRunning = false;
    }

    public void Dispose()
    {
        timer?.Dispose();
    }

    public List<Exercise>? Exercises {get; set; }
}